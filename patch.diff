@@
 def obter_label(dicionario_inverso, chave_busca):
@@
     for label, id_ in dicionario_inverso.items():
         if str(id_) == str(chave_busca):
             return label
     return str(chave_busca)
+
+
+def selectbox_with_placeholder(
+    label: str,
+    options_dict: dict,
+    selected_id=None,
+    required: bool = False,
+    disabled: bool = False,
+) -> str | None:
+    """Renderiza um selectbox com opção vazia e seleção por ID."""
+    suffix = " *" if required else ""
+    labels = ["— selecione —"] + list(options_dict.keys())
+    index = 0
+
+    if selected_id is not None:
+        for i, (_, value) in enumerate(options_dict.items(), start=1):
+            if str(value) == str(selected_id):
+                index = i
+                break
+        if index >= len(labels):
+            index = 0
+
+    selection = st.selectbox(label + suffix, labels, index=index, disabled=disabled)
+    return None if disabled else options_dict.get(selection)
